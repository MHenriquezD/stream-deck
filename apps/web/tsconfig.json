{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@shared/core": ["../../packages/shared/src/index.ts"],
    },
    "composite": false
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue"],
  "exclude": ["dist", "node_modules"],
  "references": [
    {"path": "../../packages/shared"}
  ]
}